import { revalidatePath } from "next/cache";
const vibeSchema = z.object({
  vibe: z
    .string()
    .min(10, { message: "Must be more than 10 characters." })
    .regex(/^[a-z-]+$/),
  description: z.string().min(20),
  url: z.url(),
});

interface createVibeFormState {
  errors: {
    vibe?: string[];
    description?: string[];
    _form?: string[];
  };
}

export async function createTopic(
  formState: createVibeFormState,
  formData: FormData,
): Promise<createVibeFormState> {
  //promise is what we wanna return
  const result = vibeSchema.safeParse({
    vibe: formData.get("vibe"),
    description: formData.get("description"),
    url: formData.get("url"),
  });

  //   const session = await auth();
  //   if (!session || !session.user)
  //     return {
  //       errors: {
  //         _form: ["Sign in to create the topic."],
  //       },
  //     };

  if (!result.success) return { errors: result.error.flatten().fieldErrors };
  let topic: Topic;
  try {
    topic = await db.topic.create({
      data: {
        slug: result.data.title,
        description: result.data.description,
      },
    });
  } catch (err: unknown) {
    if (err instanceof Error)
      return {
        errors: {
          _form: [err.message],
        },
      };
    else
      return {
        errors: {
          _form: ["Something went wrong."],
        },
      };
  }
  revalidatePath("/");
  redirect(paths.topicShowPath(topic.slug));
  return { errors: {} };
}
